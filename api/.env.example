# Copy this file to .env and fill in your values.
# For Vercel deployment, set these in the Vercel dashboard under Environment Variables.

# Your internal API key — the Chrome extension uses this to authenticate.
API_KEY=syncup-dev-key

# MongoDB Connection String (Required)
# Set up a free cluster at https://www.mongodb.com/atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/syncup?retryWrites=true&w=majority

# SerpAPI key — used to discover LinkedIn URLs from Name + Company.
# Sign up at https://serpapi.com (100 free searches/month on the free plan).
SERP_API_KEY=your_serpapi_key_here

# RapidAPI key — used to fetch full profile data from a LinkedIn URL.
# Subscribed to 'Fresh LinkedIn Profile Data' on RapidAPI.
RAPIDAPI_KEY=your_rapidapi_key_here

# Apollo API key — used to fetch work emails and phone numbers.
# Sign up at https://www.apollo.io/ (Free tier available).
APOLLO_API_KEY=your_apollo_key_here
