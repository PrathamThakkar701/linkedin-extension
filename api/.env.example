# Copy this file to .env and fill in your values.
# For Vercel deployment, set these in the Vercel dashboard under Environment Variables.

# Your internal API key — the Chrome extension uses this to authenticate.
API_KEY=syncup-dev-key

# SerpAPI key — used by POST /api/find to discover LinkedIn URLs from Name + Company.
# Sign up at https://serpapi.com (100 free searches/month on the free plan).
SERP_API_KEY=

# Proxycurl API key — used by POST /api/enrich-url to fetch full profile data from a LinkedIn URL.
# Sign up at https://nubela.co/proxycurl (10 free credits to start).
# Alternative providers to evaluate: RocketReach, Hunter.io, Apollo.io, PeopleDataLabs.
PROXYCURL_API_KEY=
