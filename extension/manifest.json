{
  "manifest_version": 3,
  "name": "SyncUp LinkedIn Enrichment",
  "version": "1.0",
  "description": "Extract LinkedIn profiles and sync them directly to SyncUp.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://linkedin-extension-ten.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*"],
      "js": ["content.js"]
    }
  ]
}
